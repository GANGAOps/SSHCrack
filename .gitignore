# ─────────────────────────────────────────────────────────────────────────────
# sshcrack .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# Linting / type checking
.ruff_cache/
.mypy_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Project-specific
*.session
Complete_Output.txt
test.py
test_wordlist.txt
test_key.ppk

# OS
.DS_Store
Thumbs.db

# Temporary files
*.log
*.tmp
